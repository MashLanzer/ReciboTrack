rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Recibos personales ───────────────────────────────────────────────────
    // Ruta: users/{uid}/receipts/{fileName}
    match /users/{userId}/receipts/{fileName} {
      // Solo el dueño puede leer y escribir sus propios recibos
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Imágenes de grupos ───────────────────────────────────────────────────
    // Ruta: groups/{groupId}/images/{fileName}
    // (por si en el futuro se suben fotos de recibos compartidos)
    match /groups/{groupId}/images/{fileName} {
      // Cualquier usuario autenticado que sea miembro puede leer
      allow read: if request.auth != null;

      // Solo usuarios autenticados pueden subir (máx 10 MB, solo imágenes)
      allow write: if request.auth != null
          && request.resource.size <= 10 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

  }
}
