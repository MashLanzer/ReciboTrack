rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    // El usuario está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // El usuario autenticado es el dueño del recurso
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // El usuario autenticado es miembro del grupo
    function isMember(groupData) {
      return isAuth() && request.auth.uid in groupData.memberUids;
    }

    // El usuario autenticado es admin del grupo
    function isAdmin(groupData) {
      return isAuth() && request.auth.uid == groupData.adminUid;
    }

    // Valida que un gasto personal tiene los campos mínimos
    function validExpense() {
      let d = request.resource.data;
      return d.keys().hasAll(["merchant", "total", "date", "createdAt"])
          && d.merchant is string
          && d.merchant.size() > 0
          && d.total is number
          && d.total >= 0;
    }

    // Valida que un gasto de grupo tiene los campos mínimos
    function validGroupExpense() {
      let d = request.resource.data;
      return d.keys().hasAll(["merchant", "total", "date", "paidByUid", "splitWith", "splitType"])
          && d.merchant is string
          && d.total is number
          && d.total >= 0
          && d.paidByUid == request.auth.uid
          && d.splitType in ["equal", "full", "custom"];
    }

    // ─── Colecciones personales (/users/{uid}/*) ───────────────────────────────

    match /users/{userId} {
      // Perfil del usuario
      allow read, write: if isOwner(userId);

      // Gastos personales
      match /expenses/{expenseId} {
        allow read, list: if isOwner(userId);
        allow create: if isOwner(userId) && validExpense();
        allow update: if isOwner(userId) && validExpense();
        allow delete: if isOwner(userId);
      }

      // Categorías personalizadas
      match /categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }

      // Presupuestos
      match /budgets/{budgetId} {
        allow read, write: if isOwner(userId);
      }

      // Gastos recurrentes
      match /recurring/{recurringId} {
        allow read, write: if isOwner(userId);
      }

      // Metas de ahorro
      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      // Plantillas de gasto rápido
      match /templates/{templateId} {
        allow read, write: if isOwner(userId);
      }

      // Metadatos del usuario: settings, preferencias, etc.
      // Ruta: users/{uid}/meta/{docId}  (ej. meta/settings)
      match /meta/{metaId} {
        allow read, write: if isOwner(userId);
      }

      // Accesos rápidos (quick expense templates)
      match /quickExpenses/{quickExpenseId} {
        allow read, write: if isOwner(userId);
      }

      // Ingresos
      match /income/{incomeId} {
        allow read, write: if isOwner(userId);
      }

      // Proyectos (se almacenan dentro de los gastos, pero por si acaso)
      match /projects/{projectId} {
        allow read, write: if isOwner(userId);
      }

      // Cobertura wildcard: cualquier subcolección bajo users/{uid}/ no listada
      // explícitamente arriba (starred, pinnedItems, watchlist, highlights,
      // automations, groupFolders, projectBudgets, trustedCircle, categoryBudgets, …)
      match /{subcollection=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Grupos compartidos (/groups/{groupId}) ────────────────────────────────

    match /groups/{groupId} {
      // Cualquier usuario autenticado puede LEER un grupo.
      // Necesario para que la query por inviteCodes funcione antes de unirse.
      // Los datos del grupo (nombre, emoji, miembros) no son sensibles.
      allow read: if isAuth();

      // Cualquier usuario autenticado puede crear un grupo
      // (se convierte en admin automáticamente)
      allow create: if isAuth()
          && request.resource.data.adminUid == request.auth.uid
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.keys().hasAll(["name", "emoji", "adminUid", "memberUids", "members", "inviteCodes", "createdAt"]);

      allow update: if isAuth() && (
        // Admin puede cambiar cualquier cosa
        isAdmin(resource.data)
        ||
        // Miembro puede salir: su uid desaparece de memberUids, adminUid no cambia
        (
          isMember(resource.data)
          && request.resource.data.adminUid == resource.data.adminUid
          && !(request.auth.uid in request.resource.data.memberUids)
        )
        ||
        // Cualquier auth puede unirse si presenta un invite code válido:
        // - su uid NO estaba antes en memberUids
        // - su uid SÍ está en el nuevo memberUids
        // - todos los UIDs anteriores se mantienen (no borra a nadie)
        // - el invite code que usó existe en el documento actual
        (
          !(request.auth.uid in resource.data.memberUids)
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids.hasAll(resource.data.memberUids)
          && request.resource.data.adminUid == resource.data.adminUid
        )
      );

      // Solo el admin puede eliminar el grupo
      allow delete: if isAuth() && isAdmin(resource.data);

      // ── Gastos del grupo (/groups/{groupId}/expenses/{expenseId}) ────────────

      match /expenses/{expenseId} {
        // Cualquier miembro puede leer los gastos del grupo
        allow read, list: if isAuth() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);

        // Cualquier miembro puede añadir un gasto (debe ser él quien paga)
        allow create: if isAuth()
            && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
            && validGroupExpense();

        // Solo quien pagó o el admin puede editar el gasto
        allow update: if isAuth()
            && (resource.data.paidByUid == request.auth.uid
                || isAdmin(get(/databases/$(database)/documents/groups/$(groupId)).data))
            && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
            && validGroupExpense();

        // Quien pagó o el admin del grupo puede eliminar el gasto
        allow delete: if isAuth() && (
          resource.data.paidByUid == request.auth.uid
          || isAdmin(get(/databases/$(database)/documents/groups/$(groupId)).data)
        );

        // ── Comentarios (/groups/{gid}/expenses/{eid}/comments/{cid}) ──────────

        match /comments/{commentId} {
          // Cualquier miembro del grupo puede leer comentarios
          allow read, list: if isAuth()
              && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);

          // Cualquier miembro puede añadir un comentario
          allow create: if isAuth()
              && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
              && request.resource.data.keys().hasAll(["uid", "displayName", "text", "createdAt"])
              && request.resource.data.uid == request.auth.uid
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 1000;

          // Solo quien escribió el comentario puede eliminarlo
          allow delete: if isAuth()
              && resource.data.uid == request.auth.uid;
        }

        // ── Audit log (/groups/{gid}/expenses/{eid}/auditLog/{logId}) ──────────

        match /auditLog/{logId} {
          // Cualquier miembro puede leer el historial de cambios
          allow read, list: if isAuth()
              && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);

          // Cualquier miembro autenticado puede escribir entradas de auditoría
          allow create: if isAuth()
              && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
              && request.resource.data.keys().hasAll(["action", "byUid", "timestamp"])
              && request.resource.data.byUid == request.auth.uid;

          // Las entradas de auditoría no se modifican ni eliminan
          allow update, delete: if false;
        }
      }

      // ── Carpetas del grupo (/groups/{groupId}/groupFolders/{folderId}) ────────
      match /groupFolders/{folderId} {
        allow read, list: if isAuth() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
        allow create, update, delete: if isAuth() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
      }

      // ── Subcolecciones adicionales del grupo (bets, checklists, …) ────────────
      match /{subcollection=**} {
        allow read, write: if isAuth() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
      }

      // ── Liquidaciones (/groups/{groupId}/settlements/{settlementId}) ─────────

      match /settlements/{settlementId} {
        // Solo miembros pueden ver liquidaciones
        allow read, list: if isAuth() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);

        // Cualquier miembro puede registrar un pago
        allow create: if isAuth()
            && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data)
            && request.resource.data.keys().hasAll(["fromUid", "toUid", "amount", "currency", "date", "createdAt"])
            && request.resource.data.amount is number
            && request.resource.data.amount > 0;

        // Solo quien creó la liquidación o el admin puede eliminarla
        allow delete: if isAuth() && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
          || isAdmin(get(/databases/$(database)/documents/groups/$(groupId)).data)
        );
      }
    }

  }
}
